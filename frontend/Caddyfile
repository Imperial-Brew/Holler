(holler_routing) {
	handle_path /api/* {
		reverse_proxy backend:8000 {
			header_up X-Forwarded-Proto {scheme}
			header_up X-Forwarded-Prefix /api
		}
	}

	handle {
		root * /srv
		# Without explicit Cache-Control the browser heuristically caches
		# index.html and sw.js, so deploys take ages to reach devices.
		# Hashed bundles are immutable; everything else must revalidate.
		header Cache-Control "no-cache"
		header /assets/* Cache-Control "public, max-age=31536000, immutable"
		try_files {path} /index.html
		file_server
	}
}

:80 {
	import holler_routing
}

holler.drabapps.com:14443 {
	tls {
		dns porkbun {
			api_key {env.PORKBUN_API_KEY}
			api_secret_key {env.PORKBUN_API_SECRET_KEY}
		}
		resolvers 1.1.1.1
	}
	import holler_routing
}
