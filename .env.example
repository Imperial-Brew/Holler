# Postgres
POSTGRES_USER=holler
POSTGRES_PASSWORD=holler
POSTGRES_DB=holler

# Backend
CORS_ORIGINS=http://localhost
# Unused — real auth is the HOLLER_* vars below. Left for compatibility.
SECRET_KEY=change-me-in-production

# Auth — REQUIRED. The backend raises on the first login without these.
# See docs/HOLLER_AUTH_SETUP.md for the full walk-through:
#   HOLLER_JWT_SECRET  ->  python -c "import secrets; print(secrets.token_urlsafe(48))"
#   HOLLER_PW_HASH     ->  python app/holler_auth.py make-hash
HOLLER_JWT_SECRET=
HOLLER_PW_HASH=
HOLLER_USER=dustin

# Frontend (baked into the Vite build) — legacy stub, not used by auth anymore.
VITE_AUTH_TOKEN=stub-token

# Host port the frontend is served on
APP_PORT=80

# Porkbun DNS API — only needed for the public HTTPS listener on :14443
# (Let's Encrypt via DNS challenge). Plain-HTTP :80 works without these.
PORKBUN_API_KEY=
PORKBUN_API_SECRET_KEY=
